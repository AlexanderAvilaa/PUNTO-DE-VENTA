# Django Secret Key (genera una nueva en producción)
SECRET_KEY=tu-secret-key-aqui

# Modo debug (True solo en desarrollo)
DEBUG=True

# Hosts permitidos
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.x

# Base de datos (opcional si usas PostgreSQL)
DB_NAME=ebisys_db
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432